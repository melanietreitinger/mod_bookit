{{!
    @template mod_bookit/resource_catalog/resource_catalog

    Resource catalog container with categories and resources.

    Context variables:
    * contextid - System context ID
    * categories - Array of category objects

    Example context (json):
    {
        "contextid": 1,
        "categories": [
            {
                "id": 1,
                "name": "Category Name",
                "description": "Description",
                "sortorder": 0,
                "active": true,
                "resources": []
            }
        ]
    }
}}
<div class="d-flex justify-content-center">
    <div id="mod-bookit-resource-spinner" class="my-5">
        <div class="spinner-border text-primary" style="width: 4rem; height: 4rem;" role="status">
            <span class="sr-only">{{#str}}loading, core{{/str}}</span>
        </div>
    </div>
    <div id="mod-bookit-resource-content" class="d-none">
        <div class="mod-bookit-resource-catalog mt-4 pr-5 mr-5" style="min-width: 784px;"
             id="mod-bookit-resource-catalog"
             data-contextid="{{contextid}}"
             data-totalrooms="{{totalrooms}}"
             data-reactive="catalog">

        {{! Add Category and Add Resource Buttons }}
        <div class="mb-4 d-flex justify-content-between align-items-center">
            <div>
                <button class="btn btn-primary"
                        data-action="add-category"
                        id="add-category-btn">
                    {{#str}}resources:add_category, mod_bookit{{/str}}
                </button>
                <button class="btn btn-success ms-2"
                        data-action="add-resource"
                        id="add-resource-btn"
                        {{^hascategories}}disabled{{/hascategories}}
                        {{^hascategories}}title="{{#str}}resources:add_resource_no_categories, mod_bookit{{/str}}"{{/hascategories}}>
                    {{#str}}resources:add_resource, mod_bookit{{/str}}
                </button>
            </div>
            <div>
                <a href="{{config.wwwroot}}/mod/bookit/admin/resource_settings.php"
                   class="btn btn-secondary">
                    {{#str}}resources:view_settings, mod_bookit{{/str}}
                </a>
            </div>
        </div>

        {{! Room filter - rendered by roomfilter form element }}
        <div class="mb-3">
            {{^totalrooms}}
            <p class="text-muted mb-0">
                {{#str}}resources:no_rooms, mod_bookit{{/str}}
                <a href="{{rooms_url}}">{{#str}}resources:no_rooms_link, mod_bookit{{/str}}</a>
            </p>
            {{/totalrooms}}
            {{#totalrooms}}
                {{#hascategories}}{{{roomfilter}}}{{/hascategories}}
                {{^hascategories}}
                <p class="text-muted mb-0">{{#str}}resources:filter_no_resources, mod_bookit{{/str}}</p>
                {{/hascategories}}
            {{/totalrooms}}
        </div>

        {{! Table View (Default) }}
        <div id="mod-bookit-resource-table-view" class="resource-view">
            <table class="table table-borderless table-hover bg-white rounded w-100"
                   id="mod-bookit-resource-table">
                <thead class="bg-primary text-light border-bottom" style="opacity: 0.5;">
                    <tr>
                        <th scope="col" class="py-3 font-weight-bold">{{#str}}name, core{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold" style="width: 80px;">{{#str}}resources:amount, mod_bookit{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold" style="width: 200px;">{{#str}}resources:rooms, mod_bookit{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold" style="min-width: 130px; white-space: nowrap;">{{#str}}status, core{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold text-center" style="width: 80px;">{{#str}}actions, core{{/str}}</th>
                        <th scope="col" class="py-3 font-weight-bold text-center" style="width: 70px;">{{#str}}move, core{{/str}}</th>
                    </tr>
                </thead>
                {{#categories}}
                    <tbody data-region="resource-category"
                           data-categoryid="{{id}}"
                           data-category-name="{{name}}"
                           data-category-description="{{description}}"
                           data-category-sortorder="{{sortorder}}">
                        {{> mod_bookit/resource_catalog/resource_category_row }}
                        {{#resources}}
                            {{> mod_bookit/resource_catalog/resource_item_row }}
                        {{/resources}}
                    </tbody>
                {{/categories}}
                {{^categories}}
                    <tbody id="resource-no-categories-msg">
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                {{#str}}resources:no_categories, mod_bookit{{/str}}
                            </td>
                        </tr>
                    </tbody>
                {{/categories}}
            </table>
        </div>
        </div>
    </div>
</div>
